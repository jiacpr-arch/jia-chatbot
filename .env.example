# ==========================================
# JIA Chatbot — Environment Variables
# ==========================================
# คัดลอกไฟล์นี้เป็น .env แล้วใส่ค่าจริง
# ใน Vercel: Settings → Environment Variables

# ---- Claude AI ----
ANTHROPIC_API_KEY=sk-ant-...

# ---- Facebook Messenger ----
# Page Access Tokens (format: PAGE_ID=TOKEN)
FB_PAGE_ACCESS_TOKEN_JIA_CPR=     # Token สำหรับ Page jiacpr (ID: 115768024942069)
FB_PAGE_ACCESS_TOKEN_JIA_TRAINING= # Token สำหรับ Page jia1669 (ID: 1032110679988495)
FB_APP_SECRET=                     # App Secret จาก FB Developer Console
FB_VERIFY_TOKEN=jia_chatbot_verify_2026  # ใส่อะไรก็ได้ (ตั้งให้ตรงกันใน FB Webhook)

# ---- LINE Messaging API ----
LINE_CHANNEL_ACCESS_TOKEN=        # จาก LINE Developers → Messaging API
LINE_CHANNEL_SECRET=              # จาก LINE Developers → Basic settings
LINE_ALERT_GROUP_ID=              # Group ID ของห้อง LINE ที่ต้องการแจ้งเตือน

# ---- Supabase (Required for persistent follow-up + referral) ----
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJ...       # Service Role Key (ไม่ใช่ anon key)
SUPABASE_KEY=eyJ...               # Anon Key (สำหรับ referral queries)

# ---- Google Apps Script Webhook ----
# Deploy setup/google-apps-script.js เป็น Web App แล้ว copy URL มา
GOOGLE_SHEET_WEBHOOK_URL=https://script.google.com/macros/s/xxx/exec
# URL เดียวกัน หรือ deploy แยก สำหรับ Calendar booking
GOOGLE_APPS_SCRIPT_URL=https://script.google.com/macros/s/xxx/exec

# ---- Google Review Link ----
# ไปที่ Google Maps → หา JIA TRAINER CENTER → Share → Copy link
# หรือ Google Business Profile → Get more reviews → Copy link
GOOGLE_REVIEW_URL=https://g.page/r/YOUR_PLACE_ID/review

# ---- Dashboard ----
# ใส่รหัสผ่านสำหรับเข้า dashboard (ถ้าว่างจะเปิดสาธารณะ)
DASHBOARD_SECRET=jia_dashboard_2026

# ---- Google Sheet for Lead Logging (optional) ----
HANDOFF_SHEET_URL=https://script.google.com/macros/s/xxx/exec

# ---- Instagram DM ----
# Instagram Business Account ID ที่เชื่อมต่อกับ FB Page
# หาได้ที่ FB Developer Console → IG Business Account
IG_BUSINESS_ID_JIA_CPR=             # IG Business Account ID ของ Page jiacpr
IG_BUSINESS_ID_JIA_TRAINING=        # IG Business Account ID ของ Page jia1669
# ใช้ Page Access Token เดิม (FB_PAGE_ACCESS_TOKEN_JIA_CPR) ไม่ต้องตั้งค่าเพิ่ม

# ---- Admin Commands ----
# พิมพ์ /admin:<secret> stats ในแชทบอทเพื่อดูสถิติ
ADMIN_SECRET=jia_admin_2026

# ====== วิธี Deploy บน Vercel ======
# 1. Push code ขึ้น GitHub
# 2. ไปที่ vercel.com → Import Repository
# 3. Settings → Environment Variables → เพิ่มทุกค่าด้านบน
# 4. Redeploy
# 5. ตั้ง Webhook URL ใน FB Developer Console:
#    https://your-app.vercel.app/api/messenger
# 6. ตั้ง Webhook URL ใน LINE Developers:
#    https://your-app.vercel.app/api/line
# 7. Subscribe FB Webhooks: messages, messaging_postbacks, feed (comments), messaging_optins
# 8. Subscribe IG Webhooks: messages (Instagram DM)
# 9. ตั้ง LINE Rich Menu: GET https://your-app.vercel.app/api/line-richmenu?token=DASHBOARD_SECRET&action=create
#    จากนั้นอัปโหลดรูป 2500x843px ตาม instructions ที่ได้รับ
